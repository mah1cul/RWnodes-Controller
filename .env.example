BOT_TOKEN=123456:telegram-bot-token
ADMIN_IDS=123456789

# polling or webhook
BOT_MODE=polling

DB_PATH=/data/rwnodes.sqlite3
MANAGED_SSH_KEYS_DIR=/data/ssh_keys
SSH_KEY_PRESETS_DIR=/data/ssh_key_presets
ANSIBLE_TIMEOUT=900
ANSIBLE_HOST_KEY_CHECKING=false
DEFAULT_BECOME=false
MAX_TELEGRAM_OUTPUT_CHARS=3500

# Required only when BOT_MODE=webhook. Base public URL only, without path.
WEBHOOK_URL=https://hooks.example.com
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=webhook
WEBHOOK_SECRET_TOKEN=
ADDNODE_PATH=addnode

# Existing Docker network shared with Caddy.
CADDY_DOCKER_NETWORK=caddy

# true - use hardcoded Telegram custom emoji ids; false - use regular Unicode icons.
# If Telegram rejects custom emoji, the bot disables them until restart and falls back to regular icons.
PREMIUM_EMOJI_MODE=false
